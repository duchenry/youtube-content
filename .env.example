# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to version control

# Claude (Anthropic) — server-side only
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

ANTHROPIC_BASE_URL=https://api.shopaikey.com

# Model overrides (optional — để trống sẽ dùng Sonnet 4.6 mặc định)
CLAUDE_MODEL_ANALYZE=claude-3-5-sonnet-20241022
CLAUDE_MODEL_RESEARCH=claude-3-5-sonnet-20241022
CLAUDE_MODEL_ENRICH=claude-3-5-sonnet-20241022

# Supabase — public URL and anon key are safe to expose (Row Level Security handles auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
